{
  "manifest_version": 3,
  "name": "Pulihku Safe Browse",
  "version": "1.1",
  "description": "Ekstensi pendamping Pulihku untuk memblokir pemicu dan situs dewasa di tingkat browser.",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "*://*.google.com/*",
    "*://*.bing.com/*",
    "*://*.duckduckgo.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://localhost/*",
        "*://127.0.0.1/*",
        "https://stalwart-vacherin-41ea98.netlify.app/*",
        "https://pulihku.netlify.app/*"
      ],
      "js": ["content_script.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Pulihku Safe Browse Aktif"
  }
}
